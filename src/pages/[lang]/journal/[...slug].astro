---
import { Image } from "astro:assets";
import {
  getCollection,
  render,
  type CollectionEntry,
} from "astro:content";

import { getEntryPath, type Locale } from "../../../i18n/config.ts";
import EntryMedia from "../../../components/EntryMedia.astro";
import EntryLayout from "../../../layouts/EntryLayout.astro";
import {
  getAvailableTranslations,
  getPublishedEntries,
} from "../../../lib/content.ts";
import { getEntryLocalePaths } from "../../../lib/seo.ts";
import TableOfContents from "../../../components/TableOfContents.astro";
import {
  getTableOfContentsHeadings,
  shouldShowTableOfContents,
} from "../../../lib/toc.ts";

interface Props {
  readonly entry: CollectionEntry<"journal">;
  readonly availableLocales: readonly Locale[];
}

export async function getStaticPaths() {
  const entries = getPublishedEntries(await getCollection("journal"));

  return entries.map((entry) => ({
    params: {
      lang: entry.data.locale,
      slug: entry.data.translationKey,
    },
    props: {
      entry,
      availableLocales: getAvailableTranslations(
        entries,
        entry.data.translationKey,
      ).map((translation) => translation.data.locale),
    },
  }));
}

const { entry, availableLocales } = Astro.props;
const locale = entry.data.locale;
const paths = getEntryLocalePaths(
  "journal",
  entry.data.translationKey,
  availableLocales,
);
const canonicalPath = getEntryPath(
  locale,
  "journal",
  entry.data.translationKey,
);
const { Content, headings } = await render(entry);
const tableOfContentsHeadings = getTableOfContentsHeadings(headings);
const showTableOfContents = shouldShowTableOfContents(headings);
---

<EntryLayout
  locale={locale}
  section="journal"
  title={entry.data.title}
  description={entry.data.summary}
  canonicalPath={canonicalPath}
  switchPaths={paths.switchPaths}
  alternatePaths={paths.alternatePaths}
  date={entry.data.publishedAt}
  dateKind="published"
  updatedAt={entry.data.updatedAt}
  location={undefined}
  topics={entry.data.topics}
>
  {
    showTableOfContents && (
      <TableOfContents
        slot="toc"
        locale={locale}
        headings={tableOfContentsHeadings}
      />
    )
  }
  {
    entry.data.cover !== undefined && entry.data.coverAlt !== undefined && (
      <figure slot="cover" class="entry-media">
        <Image src={entry.data.cover} alt={entry.data.coverAlt} />
      </figure>
    )
  }
  {
    entry.data.leadMedia !== undefined && (
      <EntryMedia locale={locale} media={entry.data.leadMedia} />
    )
  }
  <Content />
</EntryLayout>
