---
import { getCollection } from "astro:content";

import ContentSearch from "../../../components/ContentSearch.astro";
import EmptyState from "../../../components/EmptyState.astro";
import JournalPreview from "../../../components/JournalPreview.astro";
import { SITE_COPY } from "../../../data/site.ts";
import {
  LOCALES,
  type Locale,
} from "../../../i18n/config.ts";
import { UI_TRANSLATIONS } from "../../../i18n/translations.ts";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  createJournalSearchDocuments,
  getPublishedEntries,
} from "../../../lib/content.ts";
import { getCoreLocalePaths } from "../../../lib/seo.ts";

interface Props {
  readonly locale: Locale;
}

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;
const copy = UI_TRANSLATIONS[locale];
const paths = getCoreLocalePaths("journal");
const allEntries = await getCollection("journal");
const entries = getPublishedEntries(allEntries).filter(
  (entry) => entry.data.locale === locale,
);
const searchDocuments = createJournalSearchDocuments(allEntries, locale);
---

<SiteLayout
  locale={locale}
  currentLocale={locale}
  route="journal"
  title={copy.navigation.journal}
  description={SITE_COPY[locale].introduction}
  canonicalPath={paths[locale]}
  switchPaths={paths}
  alternatePaths={paths}
>
  <div class="page-shell">
    <header class="page-header">
      <h1>{copy.navigation.journal}</h1>
    </header>
    <section class="content-section" aria-label={copy.navigation.journal}>
      <ContentSearch
        locale={locale}
        section="journal"
        documents={searchDocuments}
      />
      {
        entries.length === 0 ? (
          <EmptyState message={copy.emptyState.journal} />
        ) : (
          <div class="journal-index">
            {entries.map((entry) => (
              <JournalPreview entry={entry} locale={locale} variant="row" />
            ))}
          </div>
        )
      }
    </section>
  </div>
</SiteLayout>
