---
import { getCollection } from "astro:content";

import ContentSearch from "../../../components/ContentSearch.astro";
import EmptyState from "../../../components/EmptyState.astro";
import MomentPreview from "../../../components/MomentPreview.astro";
import { SITE_COPY } from "../../../data/site.ts";
import {
  LOCALES,
  type Locale,
} from "../../../i18n/config.ts";
import { UI_TRANSLATIONS } from "../../../i18n/translations.ts";
import SiteLayout from "../../../layouts/SiteLayout.astro";
import {
  createMomentSearchDocuments,
  getPublishedEntries,
} from "../../../lib/content.ts";
import { getCoreLocalePaths } from "../../../lib/seo.ts";

interface Props {
  readonly locale: Locale;
}

export function getStaticPaths() {
  return LOCALES.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;
const copy = UI_TRANSLATIONS[locale];
const paths = getCoreLocalePaths("moments");
const allEntries = await getCollection("moments");
const entries = getPublishedEntries(allEntries).filter(
  (entry) => entry.data.locale === locale,
);
const searchDocuments = createMomentSearchDocuments(allEntries, locale);
---

<SiteLayout
  locale={locale}
  currentLocale={locale}
  route="moments"
  title={copy.navigation.moments}
  description={SITE_COPY[locale].introduction}
  canonicalPath={paths[locale]}
  switchPaths={paths}
  alternatePaths={paths}
>
  <div class="page-shell">
    <header class="page-header">
      <h1>{copy.navigation.moments}</h1>
    </header>
    <section class="content-section" aria-label={copy.navigation.moments}>
      <ContentSearch
        locale={locale}
        section="moments"
        documents={searchDocuments}
      />
      {
        entries.length === 0 ? (
          <EmptyState message={copy.emptyState.moments} />
        ) : (
          <div class="moments-index">
            {entries.map((entry, index) => (
              <MomentPreview
                entry={entry}
                locale={locale}
                variant={index % 3 === 1 ? "square" : "compact"}
                priority={index === 0}
              />
            ))}
          </div>
        )
      }
    </section>
  </div>
</SiteLayout>
