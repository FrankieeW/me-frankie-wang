---
import { Image } from "astro:assets";
import {
  getCollection,
  render,
  type CollectionEntry,
} from "astro:content";

import { getEntryPath, type Locale } from "../../../i18n/config.ts";
import EntryMedia from "../../../components/EntryMedia.astro";
import EntryLayout from "../../../layouts/EntryLayout.astro";
import {
  getAvailableTranslations,
  getPublishedEntries,
} from "../../../lib/content.ts";
import { getEntryLocalePaths } from "../../../lib/seo.ts";

interface Props {
  readonly entry: CollectionEntry<"moments">;
  readonly availableLocales: readonly Locale[];
}

export async function getStaticPaths() {
  const entries = getPublishedEntries(await getCollection("moments"));

  return entries.map((entry) => ({
    params: {
      lang: entry.data.locale,
      slug: entry.data.translationKey,
    },
    props: {
      entry,
      availableLocales: getAvailableTranslations(
        entries,
        entry.data.translationKey,
      ).map((translation) => translation.data.locale),
    },
  }));
}

const { entry, availableLocales } = Astro.props;
const locale = entry.data.locale;
const paths = getEntryLocalePaths(
  "moments",
  entry.data.translationKey,
  availableLocales,
);
const canonicalPath = getEntryPath(
  locale,
  "moments",
  entry.data.translationKey,
);
const { Content } = await render(entry);
const video =
  entry.data.video === undefined
    ? undefined
    : { type: "video" as const, ...entry.data.video };
---

<EntryLayout
  locale={locale}
  section="moments"
  title={entry.data.caption}
  description={entry.data.caption}
  canonicalPath={canonicalPath}
  switchPaths={paths.switchPaths}
  alternatePaths={paths.alternatePaths}
  date={entry.data.takenAt}
  dateKind="taken"
  updatedAt={undefined}
  location={entry.data.location}
  topics={entry.data.topics}
>
  {
    entry.data.images.map((image) => (
      <figure class="entry-media">
        <Image src={image.src} alt={image.alt} />
      </figure>
    ))
  }
  {video !== undefined && <EntryMedia locale={locale} media={video} />}
  <Content />
</EntryLayout>
