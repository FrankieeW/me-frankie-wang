---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE } from "../data/site.ts";
import {
  LOCALES,
  type Locale,
  type LocalizedRoute,
} from "../i18n/config.ts";
import { UI_TRANSLATIONS } from "../i18n/translations.ts";
import {
  getCanonicalUrl,
  type AlternatePathMap,
  type LocalePathMap,
} from "../lib/seo.ts";
import "../styles/global.css";

interface Props {
  readonly locale: Locale;
  readonly route: LocalizedRoute;
  readonly title?: string;
  readonly description: string;
  readonly canonicalPath: string;
  readonly switchPaths: LocalePathMap;
  readonly alternatePaths: AlternatePathMap;
}

const {
  locale,
  route,
  title,
  description,
  canonicalPath,
  switchPaths,
  alternatePaths,
} = Astro.props;
const pageTitle = title === undefined ? SITE.name : `${title} — ${SITE.name}`;
const canonicalUrl = getCanonicalUrl(canonicalPath);
const alternateLinks = LOCALES.flatMap((alternateLocale) => {
  const path = alternatePaths[alternateLocale];
  return path === undefined
    ? []
    : [{ locale: alternateLocale, href: getCanonicalUrl(path) }];
});
const defaultPath = alternatePaths.en;
const openGraphLocales = {
  en: "en_GB",
  zh: "zh_CN",
  fr: "fr_FR",
} as const satisfies Record<Locale, string>;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />
    {
      alternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.locale} href={link.href} />
      ))
    }
    {
      defaultPath !== undefined && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={getCanonicalUrl(defaultPath)}
        />
      )
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={openGraphLocales[locale]} />
    {
      alternateLinks
        .filter((link) => link.locale !== locale)
        .map((link) => (
          <meta
            property="og:locale:alternate"
            content={openGraphLocales[link.locale]}
          />
        ))
    }
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {UI_TRANSLATIONS[locale].accessibility.skipToContent}
    </a>
    <Header locale={locale} route={route} switchPaths={switchPaths} />
    <main id="main-content">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
