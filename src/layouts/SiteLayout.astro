---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE } from "../data/site.ts";
import {
  LOCALES,
  type Locale,
  type LocalizedRoute,
} from "../i18n/config.ts";
import { UI_TRANSLATIONS } from "../i18n/translations.ts";
import {
  getCanonicalUrl,
  type AlternatePathMap,
  type LocalePathMap,
} from "../lib/seo.ts";
import "../styles/global.css";

interface CommonProps {
  readonly locale: Locale;
  readonly currentLocale: Locale | undefined;
  readonly route: LocalizedRoute | undefined;
  readonly title?: string;
  readonly description: string;
  readonly switchPaths: LocalePathMap;
}

interface CanonicalMetadataProps {
  readonly canonicalPath: string;
  readonly alternatePaths: AlternatePathMap;
  readonly robots?: "index, follow";
}

interface NoIndexMetadataProps {
  readonly canonicalPath?: never;
  readonly alternatePaths?: never;
  readonly robots: "noindex, follow";
}

type Props = CommonProps & (CanonicalMetadataProps | NoIndexMetadataProps);

const {
  locale,
  currentLocale,
  route,
  title,
  description,
  switchPaths,
  robots = "index, follow",
} = Astro.props;
const pageTitle = title === undefined ? SITE.name : `${title} — ${SITE.name}`;
const canonicalUrl =
  Astro.props.canonicalPath === undefined
    ? undefined
    : getCanonicalUrl(Astro.props.canonicalPath);
const alternateLinks =
  Astro.props.alternatePaths === undefined
    ? []
    : LOCALES.flatMap((alternateLocale) => {
        const path = Astro.props.alternatePaths?.[alternateLocale];
        return path === undefined
          ? []
          : [{ locale: alternateLocale, href: getCanonicalUrl(path) }];
      });
const defaultPath = Astro.props.alternatePaths?.en;
const openGraphLocales = {
  en: "en_GB",
  zh: "zh_CN",
  fr: "fr_FR",
} as const satisfies Record<Locale, string>;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    {
      canonicalUrl !== undefined && (
        <link rel="canonical" href={canonicalUrl} />
      )
    }
    {
      alternateLinks.map((link) => (
        <link rel="alternate" hreflang={link.locale} href={link.href} />
      ))
    }
    {
      defaultPath !== undefined && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={getCanonicalUrl(defaultPath)}
        />
      )
    }
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {
      canonicalUrl !== undefined && (
        <meta property="og:url" content={canonicalUrl} />
      )
    }
    <meta property="og:locale" content={openGraphLocales[locale]} />
    {
      alternateLinks
        .filter((link) => link.locale !== locale)
        .map((link) => (
          <meta
            property="og:locale:alternate"
            content={openGraphLocales[link.locale]}
          />
        ))
    }
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">
      {UI_TRANSLATIONS[locale].accessibility.skipToContent}
    </a>
    <Header
      locale={locale}
      currentLocale={currentLocale}
      route={route}
      switchPaths={switchPaths}
    />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
