---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type PhotoFrameVariant = "hero" | "lead" | "square" | "secondary";

interface Props {
  readonly variant: PhotoFrameVariant;
  readonly image?: {
    readonly src: ImageMetadata;
    readonly alt: string;
  };
  readonly priority?: boolean;
}

const { variant, image, priority = false } = Astro.props;
const sizes =
  variant === "hero"
    ? "(max-width: 680px) calc(100vw - 44px), 382px"
    : "(max-width: 680px) calc(100vw - 44px), (max-width: 1024px) 62vw, 640px";
---

<div
  class:list={["photo-frame", `photo-frame--${variant}`]}
  aria-hidden={image === undefined ? "true" : undefined}
>
  {
    image === undefined ? (
      <div class="photo-frame__abstract">
        <span class="photo-frame__number">01</span>
      </div>
    ) : (
      <Image
        src={image.src}
        alt={image.alt}
        widths={[320, 480, 640, 960]}
        sizes={sizes}
        loading={priority ? "eager" : "lazy"}
        fetchpriority={priority ? "high" : undefined}
        decoding="async"
        format="avif"
      />
    )
  }
</div>

<style>
  .photo-frame {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--color-ink);
    background: var(--color-soft);
  }

  .photo-frame--hero {
    aspect-ratio: 1;
    overflow: visible;
    border-radius: 24px;
  }

  .photo-frame--hero::before {
    content: "";
    position: absolute;
    inset: 9px -9px -9px 9px;
    z-index: -1;
    border: 1px dashed var(--color-line-strong);
    border-radius: 26px;
  }

  .photo-frame--lead {
    aspect-ratio: 16 / 10;
    border-radius: 18px;
  }

  .photo-frame--square {
    aspect-ratio: 1;
    border-radius: 18px;
  }

  .photo-frame--secondary {
    aspect-ratio: 4 / 3;
    border-radius: 18px;
  }

  .photo-frame :global(img),
  .photo-frame__abstract {
    width: 100%;
    height: 100%;
    border-radius: inherit;
  }

  .photo-frame :global(img) {
    object-fit: cover;
  }

  .photo-frame__abstract {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 76% 27%,
        var(--color-peach) 0 9%,
        transparent 9.5%
      ),
      radial-gradient(
        circle at 75% 28%,
        var(--color-accent) 0 19%,
        transparent 19.5%
      ),
      linear-gradient(
        150deg,
        transparent 0 44%,
        rgb(255 255 255 / 50%) 44% 45%,
        transparent 45%
      ),
      linear-gradient(
        155deg,
        var(--color-blue-pale) 0 38%,
        var(--color-blue) 38% 63%,
        var(--color-ink-panel) 63% 100%
      );
  }

  .photo-frame__abstract::before {
    content: "";
    position: absolute;
    left: 47%;
    bottom: -32px;
    width: 50%;
    height: 63%;
    border: 1px solid rgb(255 255 255 / 82%);
    border-radius: 50% 50% 18% 18%;
    background: rgb(255 255 255 / 12%);
    backdrop-filter: blur(4px);
    transform: translateX(-50%) rotate(-8deg);
  }

  .photo-frame__number {
    position: absolute;
    right: var(--space-5);
    bottom: var(--space-3);
    color: rgb(255 255 255 / 90%);
    font-size: 64px;
    font-weight: 780;
    letter-spacing: -0.07em;
    line-height: 1;
  }

  @media (max-width: 680px) {
    .photo-frame--lead {
      aspect-ratio: 1.12;
    }

    .photo-frame--secondary {
      aspect-ratio: 9 / 10;
    }
  }
</style>
