---
import type { TopicKey } from "../data/topics.ts";
import type { Locale } from "../i18n/config.ts";
import { UI_TRANSLATIONS } from "../i18n/translations.ts";
import { getTopicLinks } from "../lib/content.ts";

interface Props {
  readonly locale: Locale;
  readonly topics: readonly TopicKey[];
}

const { locale, topics } = Astro.props;
const links = getTopicLinks(locale, topics);
---

{
  links.length > 0 && (
    <ul
      class="topic-links"
      aria-label={UI_TRANSLATIONS[locale].discovery.topics}
    >
      {links.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))}
    </ul>
  )
}

<style>
  .topic-links {
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    list-style: none;
    color: var(--color-muted);
    font-size: 12px;
    font-weight: 650;
    line-height: 1.45;
  }

  a {
    color: inherit;
    text-decoration-line: underline;
    text-decoration-color: var(--color-line-strong);
    text-underline-offset: var(--space-1);
  }

  a:hover,
  a:focus-visible {
    color: var(--color-accent-ink);
    text-decoration-color: currentColor;
  }
</style>
