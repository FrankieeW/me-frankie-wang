---
import {
  getSocialLinks,
  type SocialService,
} from "../data/site.ts";
import type { Locale } from "../i18n/config.ts";
import { UI_TRANSLATIONS } from "../i18n/translations.ts";

interface Props {
  readonly locale: Locale;
}

const SERVICE_NAMES = {
  website: "frankie.wang",
  instagram: "Instagram",
  rss: "RSS",
  x: "X",
  github: "GitHub",
  telegram: "Telegram",
  bilibili: "Bilibili",
  email: "Email",
  douban: "Douban",
} as const satisfies Record<SocialService, string>;

const { locale } = Astro.props;
const links = getSocialLinks(locale);
---

{
  links.length > 0 && (
    <nav
      class="social-links"
      aria-label={UI_TRANSLATIONS[locale].accessibility.socialNavigation}
    >
      {links.map((link) => {
        const name = SERVICE_NAMES[link.service];
        return (
          <a
            class:list={["social-link", `social-link--${link.service}`]}
            href={link.href}
            rel={link.rel}
            data-social-service={link.service}
            aria-label={name}
            data-label={name}
          >
            {link.service === "website" && (
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="9" />
                <path d="M3 12h18M12 3c2.4 2.5 3.6 5.5 3.6 9S14.4 18.5 12 21c-2.4-2.5-3.6-5.5-3.6-9S9.6 5.5 12 3Z" />
              </svg>
            )}
            {link.service === "instagram" && (
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
              </svg>
            )}
            {link.service === "rss" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <circle cx="5" cy="19" r="2" />
                <path d="M3 3.8v3.1c7.8 0 14.1 6.3 14.1 14.1h3.1C20.2 11.5 12.5 3.8 3 3.8Zm0 6.2v3.1c4.4 0 7.9 3.5 7.9 7.9H14c0-6.1-4.9-11-11-11Z" />
              </svg>
            )}
            {link.service === "x" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.2 2h3.4l-7.4 8.5L23 22h-6.9l-5.4-7-6.1 7H1.2l7.9-9L.7 2h7.1l4.8 6.4L18.2 2Zm-1.2 18h1.9L6.8 3.9h-2L17 20Z" />
              </svg>
            )}
            {link.service === "github" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.5 2 2 6.6 2 12.2c0 4.5 2.9 8.3 6.8 9.7.5.1.7-.2.7-.5v-2c-2.8.6-3.4-1.2-3.4-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 2.9.9.1-.7.4-1.1.7-1.4-2.2-.3-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.8 1.1A9.4 9.4 0 0 1 12 6.7c.9 0 1.7.1 2.5.3 2-1.4 2.8-1.1 2.8-1.1.5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.7-4.6 5 .4.3.7 1 .7 1.9v3.2c0 .4.2.6.7.5 4-1.4 6.8-5.2 6.8-9.7C22 6.6 17.5 2 12 2Z" />
              </svg>
            )}
            {link.service === "telegram" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M21.6 3.1 18.4 20c-.2 1.2-.9 1.5-1.9.9l-4.9-3.6-2.4 2.3c-.3.3-.5.5-1 .5l.4-5 9.1-8.3c.4-.4-.1-.6-.6-.2L5.8 13.7.9 12.2c-1.1-.3-1.1-1.1.2-1.6L20.2 3c.9-.3 1.7.2 1.4.1Z" />
              </svg>
            )}
            {link.service === "bilibili" && (
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m8 3 2 3m6-3-2 3M5 7h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2Z" />
                <path d="M8 12v2m8-2v2m-7 3h6" />
              </svg>
            )}
            {link.service === "email" && (
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="m4 7 8 6 8-6" />
              </svg>
            )}
            {link.service === "douban" && (
              <span class="social-link__douban" aria-hidden="true">豆</span>
            )}
          </a>
        );
      })}
    </nav>
  )
}

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 7px;
    margin-top: 26px;
  }

  .social-link {
    position: relative;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    color: var(--color-quiet);
    text-decoration: none;
    transition:
      color var(--motion-control),
      transform var(--motion-control);
  }

  .social-link:hover,
  .social-link:focus-visible {
    color: var(--social-color, var(--color-ink));
    transform: translateY(-2px);
  }

  .social-link:active {
    transform: translateY(-1px);
  }

  .social-link::after {
    content: attr(data-label);
    position: absolute;
    z-index: 30;
    bottom: calc(100% + var(--space-2));
    left: 50%;
    width: max-content;
    max-width: 150px;
    padding: var(--space-1) 7px;
    border: 1px solid var(--color-ink);
    border-radius: 5px;
    background: var(--color-paper);
    box-shadow: 2px 2px 0 var(--color-ink);
    color: var(--color-ink);
    font-size: 10px;
    font-weight: 700;
    line-height: 1.2;
    opacity: 0;
    pointer-events: none;
    transform: translate(-50%, var(--space-1));
    transition:
      opacity var(--motion-micro),
      transform var(--motion-micro);
  }

  .social-link:hover::after,
  .social-link:focus-visible::after {
    opacity: 1;
    transform: translate(-50%, 0);
  }

  .social-link:first-child::after {
    left: 0;
    transform: translate(0, var(--space-1));
  }

  .social-link:first-child:hover::after,
  .social-link:first-child:focus-visible::after {
    transform: translate(0, 0);
  }

  .social-link svg {
    width: var(--space-5);
    height: var(--space-5);
  }

  .social-link--rss {
    --social-color: var(--social-rss);
  }

  .social-link--website {
    --social-color: var(--social-website);
  }

  .social-link--instagram {
    --social-color: var(--social-instagram);
  }

  .social-link--x {
    --social-color: var(--social-x);
  }

  .social-link--github {
    --social-color: var(--social-github);
  }

  .social-link--telegram {
    --social-color: var(--social-telegram);
  }

  .social-link--bilibili {
    --social-color: var(--social-bilibili);
  }

  .social-link--email {
    --social-color: var(--social-email);
  }

  .social-link--douban {
    --social-color: var(--social-douban);
  }

  .social-link__douban {
    font-size: 19px;
    font-weight: 800;
    line-height: 1;
  }

  @media (pointer: coarse) {
    .social-links {
      gap: 3px;
    }

    .social-link {
      width: var(--control-min-size);
      height: var(--control-min-size);
    }
  }
</style>
